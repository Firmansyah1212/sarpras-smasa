generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  MENUNGGU
  DISETUJUI
  DITOLAK
  SELESAI
}

model Peminjaman {
  id         Int      @id @default(autoincrement())
  nama       String
  bagian     String
  noHp       String
  ruangan    String
  tanggal    DateTime
  jamMulai   String
  jamSelesai String
  keperluan  String
  suratPdf   String?
  status     Status   @default(MENUNGGU)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ruangan, tanggal, status])
}
